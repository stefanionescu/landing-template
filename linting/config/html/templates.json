{
  "extends": ["html-validate:recommended"],
  "rules": {
    "doctype-style": [
      "error",
      {
        "style": "lowercase"
      }
    ],
    "element-required-attributes": "error",
    "no-autoplay": "off",
    "no-inline-style": "error",
    "no-raw-characters": "error",
    "void-style": [
      "error",
      {
        "style": "selfclosing"
      }
    ],
    "wcag/h37": "error"
  }
}
