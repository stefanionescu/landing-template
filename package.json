{
    "name": "landing-template",
    "version": "1.0.0",
    "description": "Production-ready template for static landing pages",
    "scripts": {
        "---SETUP---": "-------",
        "setup:hooks": "./.githooks/lib/setup.sh",

        "---BUILD---": "-------",
        "start": "bun server.js",
        "build": "node build/index.js",

        "---LINT---": "-------",
        "lint": "concurrently 'bun run lint:code' 'bun run lint:analysis' 'bun run lint:content' 'bun run lint:config' 'bun run lint:hooks' 'bun run lint:sh' && bun run lint:links:external",
        "lint:fix": "concurrently 'eslint . --fix' 'bun run lint:md:fix' 'bun run lint:pkg:fix' && bun run format",

        "---LINT:CODE---": "-------",
        "lint:code": "concurrently 'bun run lint:js' 'bun run lint:css' 'bun run lint:html' 'bun run lint:cpd' 'bun run lint:circular' 'bun run lint:css-dead' 'bun run lint:links' 'bun run format:check'",
        "lint:js": "eslint . --max-warnings 0",
        "lint:css": "stylelint \"styles.css\"",
        "lint:html": "concurrently 'bun run lint:html:hint' 'bun run lint:html:validate' 'bun run lint:html:copy'",
        "lint:html:hint": "htmlhint \"404.html\" \"pages/landing/template.html\" \"pages/legal/template.html\"",
        "lint:html:validate": "concurrently 'bun run lint:html:validate:templates' 'bun run lint:html:validate:generated'",
        "lint:html:validate:templates": "html-validate --config linting/config/html/templates.json \"404.html\" \"pages/landing/template.html\" \"pages/legal/template.html\"",
        "lint:html:validate:generated": "html-validate --config linting/config/html/generated.json \"pages/landing/*/index.html\" \"pages/legal/*/index.html\"",
        "lint:html:copy": "node linting/html-copy.mjs",
        "lint:cpd": "concurrently 'jscpd --config .jscpd/js.json' 'jscpd --config .jscpd/css.json' 'jscpd --config .jscpd/bash.json linting'",
        "lint:circular": "madge --circular --extensions js server.js build/index.js build/steps/*.js shared/*.js config/*.js functions/_middleware.js",
        "lint:css-dead": "node linting/css-dead.mjs",
        "lint:links": "node linting/links/check.mjs internal",
        "lint:links:external": "node linting/links/check.mjs external",

        "---LINT:ANALYSIS---": "-------",
        "lint:analysis": "concurrently 'bun run lint:semgrep' 'bun run lint:complexity' 'bun run lint:knip'",
        "lint:semgrep": "bash linting/semgrep/run.sh app",
        "lint:semgrep:hooks": "bash linting/semgrep/run.sh hooks",
        "lint:complexity": "bash linting/lizard/run.sh all",
        "lint:knip": "knip --config knip.json --no-config-hints",

        "---LINT:CONTENT---": "-------",
        "lint:content": "concurrently 'bun run lint:typos' 'bun run lint:md' 'bun run lint:license'",
        "lint:typos": "typos .",
        "lint:md": "markdownlint-cli2",
        "lint:md:fix": "markdownlint-cli2 --fix",
        "lint:license": "node linting/license/check.mjs",

        "---LINT:CONFIG---": "-------",
        "lint:config": "concurrently 'bun run lint:pkg' 'bun run lint:sanity' 'bun run lint:rules'",
        "lint:pkg": "node linting/package/json.js",
        "lint:pkg:fix": "node linting/package/json.js --fix",
        "lint:sanity": "node linting/package/integrity.js",
        "lint:rules": "eslint linting --max-warnings 0",

        "---LINT:HOOKS---": "-------",
        "lint:hooks": "concurrently 'bun run lint:hooks:lint' 'bun run lint:hooks:security' 'bun run lint:hooks:format' 'bun run lint:hooks:quality'",
        "lint:hooks:lint": "bash .githooks/hooks/self/lint.sh",
        "lint:hooks:security": "bash .githooks/hooks/self/security.sh",
        "lint:hooks:format": "bash .githooks/hooks/self/format.sh",
        "lint:hooks:quality": "bash .githooks/hooks/self/quality.sh",

        "---LINT:SH---": "-------",
        "lint:sh": "concurrently 'bun run lint:sh:check' 'bun run lint:sh:format' 'bun run lint:sh:semgrep' 'bun run lint:sh:dead' 'bun run lint:sh:length' 'bun run lint:sh:justify' 'bun run lint:sh:docs' 'bun run lint:sh:naming' 'bun run lint:sh:structure'",
        "lint:sh:check": "shellcheck linting/**/*.sh linting/config/security/*.env linting/config/security/gitleaks/*.env",
        "lint:sh:format": "shfmt -d linting/**/*.sh linting/config/security/*.env linting/config/security/gitleaks/*.env",
        "lint:sh:semgrep": "semgrep --error --no-rewrite-rule-ids --metrics=off --disable-version-check --config r/bash linting",
        "lint:sh:dead": "node linting/shell/unused-functions.js --scope linting",
        "lint:sh:length": "node linting/shell/length.js --scope linting",
        "lint:sh:justify": "node linting/shell/disable-justification.js --scope linting",
        "lint:sh:docs": "node linting/shell/docs.js --scope linting",
        "lint:sh:naming": "node linting/shell/naming.js --scope linting",
        "lint:sh:structure": "node linting/shell/structure/check.js --scope linting",

        "---SECURITY---": "-------",
        "security:gitleaks": "bash linting/security/gitleaks/run.sh detect --no-banner --redact --source . --baseline-path linting/config/security/gitleaks/baseline.json",
        "security:osv": "bash linting/security/osv/run.sh scan --recursive .",
        "security:scan": "concurrently 'bun run lint:semgrep' 'bun run lint:semgrep:hooks' 'bun run security:gitleaks' 'bun run security:osv'",

        "---FORMAT---": "-------",
        "format": "prettier . --write",
        "format:check": "prettier . --check"
    },
    "private": true,
    "engines": {
        "node": ">=20.0.0 <21.0.0"
    },
    "devDependencies": {
        "@commitlint/cli": "20.4.3",
        "@commitlint/config-conventional": "20.4.3",
        "@eslint/js": "10.0.1",
        "concurrently": "9.2.1",
        "eslint": "10.0.3",
        "eslint-config-prettier": "10.1.8",
        "html-validate": "10.4.0",
        "htmlhint": "1.9.2",
        "jscpd": "4.0.8",
        "knip": "5.86.0",
        "license-checker": "25.0.1",
        "linkinator": "6.1.4",
        "madge": "8.0.0",
        "markdownlint-cli2": "0.21.0",
        "markdownlint-rule-extended-ascii": "0.2.1",
        "prettier": "3.8.1",
        "purgecss": "8.0.0",
        "stylelint": "17.4.0",
        "stylelint-config-standard": "40.0.0",
        "typos": "1.0.1"
    },
    "packageManager": "bun@1.2.7",
    "overrides": {
        "@eslint/plugin-kit": "0.6.0",
        "minimatch": "10.2.3",
        "tar": "7.5.10"
    }
}
